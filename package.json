{
  "name": "vitest-feishu-reporter",
  "version": "1.0.0",
  "description": "Send Vitest test failures to Feishu (Lark)",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.14.0",
  "homepage": "https://github.com/justjavac/vitest-feishu-reporter",
  "bugs": "https://github.com/justjavac/vitest-feishu-reporter/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justjavac/vitest-feishu-reporter.git"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('./dist', {recursive: true, force: true})\"",
    "build": "tsc --project tsconfig.prod.json",
    "dev": "vitest",
    "lint": "oxlint . && publint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "validate": "pnpm build && pnpm lint && pnpm typecheck && pnpm test run"
  },
  "peerDependencies": {
    "vitest": ">=3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "vitest",
    "vitest-reporter",
    "feishu",
    "lark",
    "test"
  ],
  "prettier": {},
  "license": "MIT"
}
